{
  "schemaVersion": 1,
  "kind": "sdkwork.app.config",
  "application": {
    "code": "sdkwork-search-flutter-mobile",
    "name": "SDKWork Search Flutter Mobile",
    "description": "Flutter mobile search application for SDKWork.",
    "version": "0.1.0",
    "runtime": {
      "family": "mobile",
      "framework": "flutter",
      "targets": ["ios", "android"]
    },
    "domain": "intelligence",
    "capability": "search",
    "owner": "sdkwork-search"
  },
  "specs": {
    "root": "../sdkwork-specs",
    "architecture": "FLUTTER_APP_MOBILE_ARCHITECTURE_SPEC.md",
    "ui": "APP_FLUTTER_UI_SPEC.md"
  },
  "packages": {
    "workspace": "pubspec.yaml"
  },
  "verification": {
    "commands": [
      "flutter analyze",
      "flutter test"
    ]
  }
}
