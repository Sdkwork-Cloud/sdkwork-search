{
  "schemaVersion": 1,
  "kind": "sdkwork.app.config",
  "application": {
    "code": "sdkwork-search-h5",
    "name": "SDKWork Search H5",
    "description": "Phone-first H5/Capacitor search application for SDKWork.",
    "version": "0.1.0",
    "runtime": {
      "family": "mobile",
      "framework": "react",
      "targets": ["browser", "capacitor"]
    },
    "domain": "intelligence",
    "capability": "search",
    "owner": "sdkwork-search"
  },
  "specs": {
    "root": "../sdkwork-specs",
    "architecture": "APP_H5_ARCHITECTURE_SPEC.md",
    "ui": "APP_MOBILE_REACT_UI_SPEC.md"
  },
  "packages": {
    "workspace": "pnpm-workspace.yaml"
  },
  "verification": {
    "commands": [
      "pnpm typecheck",
      "pnpm test"
    ]
  }
}
