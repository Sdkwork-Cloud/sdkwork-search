{
  "name": "@sdkwork/search-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "stop": "node ../sdkwork-specs/tools/stop-sdkwork-workspace-processes.mjs --workspace .",
    "test": "vitest run",
    "test:contracts": "vitest run apps/sdkwork-search-common/packages/sdkwork-search-contracts/tests/searchContracts.test.ts",
    "test:pc-react": "vitest run apps/sdkwork-search-pc/packages/sdkwork-search-pc-react/tests/search.test.ts",
    "test:h5-react": "vitest run apps/sdkwork-search-h5/packages/sdkwork-search-h5-react/tests/search.test.ts",
    "test:governance": "node scripts/search-governance.test.mjs",
    "typecheck": "tsc --noEmit",
    "sdk:materialize": "node sdks/materialize-search-v3-openapi-boundaries.mjs",
    "sdk:generate:app": "powershell -ExecutionPolicy Bypass -File sdks/sdkwork-search-app-sdk/bin/generate-sdk.ps1",
    "sdk:generate:backend": "powershell -ExecutionPolicy Bypass -File sdks/sdkwork-search-backend-sdk/bin/generate-sdk.ps1",
    "db:materialize:contract": "node ../sdkwork-specs/tools/materialize-database-contract-from-baseline.mjs --root . --baseline database/ddl/baseline/postgres/0001_search_baseline.sql --module-id search --owner search-platform --prefixes search_ --engines postgres",
    "db:validate": "node ../sdkwork-specs/tools/check-database-framework-standard.mjs --root .",
    "db:plan": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . plan",
    "db:init": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . init",
    "db:migrate": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . migrate",
    "db:seed": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . seed",
    "db:status": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . status",
    "db:drift": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift",
    "db:drift:check": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift-check",
    "db:bootstrap": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . bootstrap",
    "test:contract:database": "node ../sdkwork-specs/tools/check-database-framework-standard.mjs --root .",
    "api:assembly:materialize": "node ../sdkwork-specs/tools/materialize-api-assembly.mjs --root .",
    "api:assembly:validate": "node ../sdkwork-specs/tools/validate-api-assembly.mjs --root .",
    "check:app-composition": "node ../sdkwork-specs/tools/verify-repo.mjs --root ."
  },
  "devDependencies": {
    "@sdkwork/sdk-common": "workspace:*",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "react": ">=18.2.0 <20.0.0",
    "react-dom": ">=18.2.0 <20.0.0"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  }
}
