{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@sdkwork/search-contracts": [
        "packages/common/search/sdkwork-search-contracts/src/index.ts"
      ],
      "@sdkwork/search-service": [
        "packages/common/search/sdkwork-search-service/src/index.ts"
      ],
      "@sdkwork/search-h5-react": [
        "apps/sdkwork-search-h5/packages/sdkwork-search-h5-react/src/index.ts"
      ],
      "@sdkwork/search-pc-react": [
        "apps/sdkwork-search-pc/packages/sdkwork-search-pc-react/src/index.ts"
      ],
      "@sdkwork/sdk-common": [
        "../sdkwork-sdk-commons/sdkwork-sdk-common-typescript/dist/index.d.ts"
      ],
      "@sdkwork/sdk-common/*": [
        "../sdkwork-sdk-commons/sdkwork-sdk-common-typescript/dist/*/index.d.ts"
      ]
    },
    "allowImportingTsExtensions": true,
    "strict": true,
    "noEmit": true,
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node"]
  }
}
