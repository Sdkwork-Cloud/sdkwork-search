{
  "schemaVersion": 1,
  "kind": "sdkwork.route.manifest",
  "packageName": "sdkwork-routes-search-backend-api",
  "surface": "backend-api",
  "owner": "sdkwork-search",
  "domain": "search",
  "capability": "search",
  "apiAuthority": "sdkwork-search-backend-api",
  "sdkFamily": "sdkwork-search-backend-sdk",
  "prefix": "/backend/v3/api",
  "source": {
    "crateRoot": "packages/native-rust/routes/backend-api/sdkwork-routes-search-backend-api",
    "crateImport": "sdkwork_routes_search_backend_api"
  },
  "routes": [
